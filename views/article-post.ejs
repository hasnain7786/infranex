<%- include('partials/header') %>

    <article class="article-content" style="padding: 80px 0;">
        <div class="container" style="max-width: 850px;">
            <div class="article-header" style="margin-bottom: 40px; text-align: center;">
                <span style="color: var(--secondary-color); font-weight: 700; text-transform: uppercase; font-size: 0.9rem; letter-spacing: 1px;"><%= article.category %></span>
                <h1 style="font-family: 'Playfair Display', serif; font-size: 3rem; color: var(--primary-color); margin: 20px 0; line-height: 1.2;"><%= article.title %></h1>
                <div style="color: #888; font-size: 0.95rem; display: flex; justify-content: center; gap: 20px; align-items: center;">
                    <span><i class="far fa-calendar-alt"></i> <%= article.date %></span> 
                    <span><i class="far fa-clock"></i> <%= article.readTime %></span>
                    <span><i class="far fa-user"></i> Infranex Editorial Team</span>
                </div>
            </div>

            <img src="<%= article.imageUrl %>" alt="<%= article.title %>" style="width: 100%; height: 450px; object-fit: cover; border-radius: 20px; margin-bottom: 50px; box-shadow: 0 15px 40px rgba(0,0,0,0.1);">

            <div class="article-body" style="line-height: 1.9; color: #333; font-size: 1.15rem; font-family: 'Inter', sans-serif;">
                <p style="font-size: 1.3rem; color: #555; line-height: 1.6; margin-bottom: 30px; font-weight: 500;"><%= article.excerpt %></p>
                
                <!-- Displaying actual content -->
                <div class="main-content-text">
                    <%- article.content %>
                </div>

                <!-- Dynamic Related Articles Section -->
                <div class="related-articles-section" style="margin-top: 60px; padding-top: 50px; border-top: 1px solid #eee;">
                    <h3 style="font-family: 'Playfair Display', serif; font-size: 1.8rem; color: var(--primary-color); margin-bottom: 30px; font-weight: 800;">Recommended Reading</h3>
                    <div class="related-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 25px;">
                        <% relatedArticles.forEach(related => { %>
                            <div class="related-card" style="background: #fafaf7; border-radius: 12px; overflow: hidden; box-shadow: 0 5px 15px rgba(0,0,0,0.02); transition: all 0.3s ease; border: 1px solid #f0f0eb; display: flex; flex-direction: column;">
                                <a href="/articles/<%= related.slug %>" style="display: block; overflow: hidden; height: 160px;">
                                    <img src="<%= related.imageUrl %>" alt="<%= related.title %>" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease;" class="related-img">
                                </a>
                                <div style="padding: 20px; display: flex; flex-direction: column; flex-grow: 1;">
                                    <span style="font-size: 0.7rem; font-weight: 700; color: var(--secondary-color); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; display: block;"><%= related.category %></span>
                                    <h4 style="font-family: 'Playfair Display', serif; font-size: 1.15rem; margin: 0 0 10px; line-height: 1.4; font-weight: 700; flex-grow: 1;">
                                        <a href="/articles/<%= related.slug %>" style="color: var(--primary-color); text-decoration: none; transition: color 0.3s;" class="related-title-link"><%= related.title %></a>
                                    </h4>
                                    <div style="font-size: 0.75rem; color: #888; display: flex; gap: 12px; margin-top: auto;">
                                        <span><i class="far fa-calendar-alt"></i> <%= related.date %></span>
                                        <span><i class="far fa-clock"></i> <%= related.readTime %></span>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>

            <footer style="margin-top: 80px; padding-top: 50px; border-top: 1px solid #eee;">
                <div style="display: flex; align-items: center; gap: 25px; background: #f9f9f9; padding: 40px; border-radius: 20px;">
                    <div style="width: 80px; height: 80px; background: var(--primary-color); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: 800; font-size: 1.8rem; flex-shrink: 0;">IP</div>
                    <div>
                        <h4 style="margin: 0; color: var(--primary-color); font-size: 1.2rem;">Infranex Editorial Team</h4>
                        <p style="margin: 8px 0 0; font-size: 1rem; color: #666; line-height: 1.5;">Sharing decades of publishing expertise to help authors turn their vision into a global legacy through high-quality production and strategic distribution.</p>
                    </div>
                </div>

                <div style="margin-top: 50px; text-align: center;">
                    <a href="/articles" class="btn btn-outline" style="border: 2px solid var(--primary-color); color: var(--primary-color); padding: 12px 30px; border-radius: 30px; text-decoration: none; font-weight: 700; transition: all 0.3s; display: inline-block;">
                        <i class="fas fa-chevron-left"></i> Back to All Articles
                    </a>
                </div>
            </footer>
        </div>
    </article>

    <style>
        .article-body p { margin-bottom: 25px; }
        .main-content-text { font-weight: 400; color: #333; }
        .main-content-text h2 { font-family: 'Playfair Display', serif; font-size: 2.2rem; color: var(--primary-color); margin: 40px 0 20px; font-weight: 700; line-height: 1.3; }
        .main-content-text h3 { font-family: 'Playfair Display', serif; font-size: 1.6rem; color: var(--secondary-color); margin: 30px 0 15px; font-weight: 600; }
        .main-content-text ul { margin-bottom: 25px; padding-left: 20px; }
        .main-content-text li { margin-bottom: 10px; line-height: 1.8; }
        .main-content-text strong { font-weight: 700; color: #111; }
        .related-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(61, 44, 94, 0.15) !important;
            border-color: var(--secondary-color) !important;
        }
        .related-card:hover .related-img {
            transform: scale(1.08);
        }
        .related-card:hover .related-title-link {
            color: var(--secondary-color) !important;
        }
        @media (max-width: 768px) {
            .article-content { padding: 40px 0; }
            h1 { font-size: 2.2rem !important; }
            .article-content img { height: 300px !important; }
        }
    </style>

<%- include('partials/footer') %>
