<%- include('partials/header') %>

    <!-- Page Title -->
    <section style="background: var(--primary-color); color: white; padding: 60px 0; text-align: center;">
        <div class="container" data-aos="fade-down">
            <h1>Premium eBook Publishing</h1>
            <p style="opacity: 0.8; margin-top: 10px;">Reach a global audience with flawlessly formatted digital books.
            </p>
        </div>
    </section>

    <!-- eBook Intro -->
    <section>
        <div class="container">
            <div class="responsive-grid">
                <div data-aos="fade-right">
                    <h2>The Digital Revolution of Reading</h2>
                    <p style="margin: 20px 0;">In today's fast-paced world, eBooks are a vital part of an author's
                        success. We ensure your book looks beautiful on every screen, from the smallest smartphone to
                        the largest tablet.</p>
                    <div style="background: var(--secondary-color); height: 5px; width: 60px; margin-bottom: 25px;">
                    </div>
                    <ul style="list-style: none;">
                        <li style="margin-bottom: 12px;">✅ <strong>Global Reach:</strong> Instant access for readers
                            worldwide.</li>
                        <li style="margin-bottom: 12px;">✅ <strong>Higher Royalties:</strong> Lower production costs
                            mean more for you.</li>
                        <li style="margin-bottom: 12px;">✅ <strong>Interactive Features:</strong> Internal links,
                            searchable text, and more.</li>
                    </ul>
                </div>
                <div data-aos="fade-left">
                    <img src="https://images.unsplash.com/photo-1592496001020-d31bd830651f?auto=format&fit=crop&q=80&w=800"
                        alt="eBook Devices"
                        style="width: 100%; height: 400px; object-fit: cover; border-radius: 20px; box-shadow: var(--shadow);">
                </div>
            </div>
        </div>
    </section>

    <!-- Supported Formats -->
    <style>
        .format-card {
            background: #FFFFFF;
            padding: 50px 30px;
            text-align: center;
            border-radius: 12px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.03);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative;
            overflow: hidden;
            z-index: 1;
            /* Constant breathing float */
            animation: cardBreathing 4s ease-in-out infinite alternate;
            border: 1px solid transparent;
        }

        /* Stagger the animations so they feel organic */
        .format-card:nth-child(2) {
            animation-delay: 1.2s;
        }

        .format-card:nth-child(3) {
            animation-delay: 2.4s;
        }

        @keyframes cardBreathing {
            0% {
                transform: translateY(0);
                box-shadow: 0 10px 40px rgba(0, 0, 0, 0.03);
            }

            100% {
                transform: translateY(-8px);
                box-shadow: 0 20px 45px rgba(139, 113, 214, 0.08);
            }
        }

        /* Glass Shimmer Effect */
        .format-card::after {
            content: '';
            position: absolute;
            top: 0;
            left: -150%;
            width: 50%;
            height: 100%;
            background: linear-gradient(to right, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.8) 50%, rgba(255, 255, 255, 0) 100%);
            transform: skewX(-25deg);
            z-index: 10;
        }

        .format-card:hover::after {
            animation: shine 0.8s ease-out forwards;
        }

        @keyframes shine {
            0% {
                left: -150%;
            }

            100% {
                left: 200%;
            }
        }

        /* Enhanced Hover State */
        .format-card:hover {
            transform: translateY(-20px) scale(1.03) !important;
            box-shadow: 0 25px 60px rgba(139, 113, 214, 0.25) !important;
            border: 1px solid rgba(139, 113, 214, 0.3);
            animation-play-state: paused;
        }

        .format-icon-container {
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 25px;
            filter: drop-shadow(0 5px 5px rgba(0, 0, 0, 0.05));
            transition: filter 0.4s ease;
        }

        .format-card:hover .format-icon-container {
            filter: drop-shadow(0 15px 15px rgba(139, 113, 214, 0.4));
        }

        .format-icon {
            transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .format-card:hover .format-icon {
            transform: scale(1.25) rotate(8deg);
        }

        .floating-icon {
            animation: floatIcon 3s ease-in-out infinite alternate;
        }

        @keyframes floatIcon {
            0% {
                transform: translateY(-4px);
            }

            100% {
                transform: translateY(6px);
            }
        }
    </style>

    <section style="background: #fdfcf0; padding: 100px 0;">
        <div class="container">
            <div style="text-align: center; margin-bottom: 55px;">
                <h2 data-aos="fade-up"
                    style="font-family: 'Playfair Display', serif; font-size: 2.2rem; color: #333; margin-bottom: 12px; font-weight: 700;">
                    Supported Formats</h2>
