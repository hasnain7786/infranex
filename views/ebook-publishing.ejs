                            <rect x="1" y="1" width="22" height="38" rx="3" fill="#1A1A1A" stroke="#1A1A1A"
                                stroke-width="2" />
                            <rect x="5" y="6" width="3" height="3" rx="0.5" fill="#4CAF50" />
                            <rect x="10.5" y="6" width="3" height="3" rx="0.5" fill="#2196F3" />
                            <rect x="16" y="6" width="3" height="3" rx="0.5" fill="#FFC107" />
                            <rect x="5" y="11" width="3" height="3" rx="0.5" fill="#E91E63" />
                            <rect x="10.5" y="11" width="3" height="3" rx="0.5" fill="#00BCD4" />
                            <rect x="16" y="11" width="3" height="3" rx="0.5" fill="#FF9800" />
                            <rect x="5" y="16" width="3" height="3" rx="0.5" fill="#9C27B0" />
                            <rect x="10.5" y="16" width="3" height="3" rx="0.5" fill="#8BC34A" />
                            <rect x="16" y="16" width="3" height="3" rx="0.5" fill="#03A9F4" />
                            <rect x="5" y="21" width="3" height="3" rx="0.5" fill="#FFEB3B" />
                            <rect x="10.5" y="21" width="3" height="3" rx="0.5" fill="#F44336" />
                            <rect x="16" y="21" width="3" height="3" rx="0.5" fill="#795548" />
                            <rect x="10" y="32" width="4" height="4" rx="2" fill="#333333" />
                        </svg>
                    </div>
                    <h4
                        style="font-family: 'Playfair Display', serif; font-size: 1.1rem; color: #2D2D2D; margin-bottom: 12px; font-weight: 800;">
                        Kindle (KPF/MOBI)</h4>
                    <p style="color: #666; font-size: 0.95rem; line-height: 1.6; margin: 0;">Purely optimized for the
                        world's most<br>popular eReader platform.</p>
                </div>

                <!-- EPUB -->
                <div class="format-card" data-aos="zoom-up" data-aos-delay="200">
                    <div class="format-icon-container floating-icon" style="animation-delay: 0.3s;">
                        <svg class="format-icon" width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="#4198D7"
                            stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="2" y1="12" x2="22" y2="12"></line>
                            <path
                                d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z">
                            </path>
