                                fill="#E8e8e8" />
                            <path d="M15 2L22 9H15V2Z" fill="#C4C4C4" />
                            <rect x="6" y="13" width="12" height="1" fill="#999999" />
                            <rect x="6" y="16" width="12" height="1" fill="#999999" />
                            <rect x="6" y="19" width="8" height="1" fill="#999999" />
                        </svg>
                    </div>
                    <h4
                        style="font-family: 'Playfair Display', serif; font-size: 1.1rem; color: #2D2D2D; margin-bottom: 12px; font-weight: 800;">
                        Interactive PDF</h4>
                    <p style="color: #666; font-size: 0.95rem; line-height: 1.6; margin: 0;">Perfect for direct sales
                        and fixed-<br>layout non-fiction books.</p>
                </div>

            </div>
        </div>
    </section>

    <!-- eBook Process -->
    <section style="padding: 100px 0; background: #ffffff; overflow: hidden;">
        <div class="container">
            <div style="text-align: center; margin-bottom: 80px;">
                <h2 data-aos="fade-up"
                    style="font-family: 'Playfair Display', serif; font-size: 2.2rem; color: #2D2D2D; margin-bottom: 15px; font-weight: 700;">
                    Our eBook Workflow</h2>
                <p data-aos="fade-up" data-aos-delay="100"
                    style="color: #666; font-size: 1rem; max-width: 600px; margin: 0 auto;">A seamless, professional
                    process converting your manuscript into a globally formatted digital book.</p>
            </div>

            <div class="workflow-container">
                <div class="workflow-text" data-aos="fade-right">
                    <div class="workflow-step-text">
                        <div class="step-line-indicator"></div>
                        <h4
                            style="color: #2D2D2D; font-family: 'Playfair Display', serif; font-size: 1.4rem; margin-bottom: 8px; font-weight: 700;">
                            Reflowable Formatting</h4>
                        <p style="color: #666; font-size: 0.95rem; line-height: 1.7; margin: 0;">We convert your
                            manuscript into a reflowable layout that adapts to any screen size and user font preference,
                            ensuring universal readability.</p>
                    </div>

                    <div class="workflow-step-text">
                        <div class="step-line-indicator"></div>
                        <h4
                            style="color: #2D2D2D; font-family: 'Playfair Display', serif; font-size: 1.4rem; margin-bottom: 8px; font-weight: 700;">
                            Fixed Layout (Optional)</h4>
                        <p style="color: #666; font-size: 0.95rem; line-height: 1.7; margin: 0;">For children's books or
                            photography books, we preserve the exact design using advanced fixed-layout technology.</p>
                    </div>

                    <div class="workflow-step-text">
                        <div class="step-line-indicator"></div>
                        <h4
                            style="color: #2D2D2D; font-family: 'Playfair Display', serif; font-size: 1.4rem; margin-bottom: 8px; font-weight: 700;">
                            Multi-Device Testing</h4>
                        <p style="color: #666; font-size: 0.95rem; line-height: 1.7; margin: 0;">We test your eBook on
                            Kindles, iPads, Android tablets, and various eReader apps to ensure flawless presentation
                            worldwide.</p>
                    </div>
                </div>

                <div class="workflow-graphic" data-aos="fade-left" data-aos-delay="200">
                    <div class="workflow-illustration">
                        <div
                            style="width: 280px; height: 280px; background: #fbfaff; border-radius: 50%; display: flex; align-items: center; justify-content: center; position: relative; box-shadow: 0 10px 40px rgba(139, 113, 214, 0.1);">
                            <!-- Document -->
                            <svg width="120" height="150" viewBox="0 0 24 28" fill="none"
                                style="position: absolute; transform: rotate(-8deg); left: 50px; top: 40px; z-index: 2;">
                                <path
                                    d="M15 2H4C2.89543 2 2 2.89543 2 4V24C2 25.1046 2.89543 26 4 26H20C21.1046 26 22 25.1046 22 24V9L15 2Z"
                                    fill="#ffffff" stroke="#8b71d6" stroke-width="1.5" />
                                <path d="M15 2L22 9H15V2Z" fill="#f4f2fb" stroke="#8b71d6" stroke-width="1.5" />
                                <rect x="6" y="10" width="8" height="1.5" fill="#8b71d6" />
                                <rect x="6" y="14" width="12" height="1.5" fill="#8b71d6" />
                                <rect x="6" y="18" width="12" height="1.5" fill="#8b71d6" />
                            </svg>

                            <!-- Mobile/Tablet -->
                            <svg width="100" height="140" viewBox="0 0 24 34" fill="none"
                                style="position: absolute; right: 35px; bottom: 25px; z-index: 3;">
                                <rect x="2" y="2" width="20" height="30" rx="3" fill="#ffffff" stroke="#a491d9"
                                    stroke-width="1.5" box-shadow="0 5px 15px rgba(0,0,0,0.1)" />
                                <rect x="4" y="5" width="16" height="20" rx="1" fill="#f4f2fb" />
                                <circle cx="12" cy="29" r="1.5" fill="#a491d9" />
                                <polygon points="10,12 15,15 10,18" fill="#8b71d6" />
                            </svg>

                            <!-- Decor elements -->
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none"
                                style="position: absolute; left: 20px; top: 50px; z-index: 1; animation: floatNode 4s infinite alternate reverse;">
                                <path d="M12 2L13.5 10.5L22 12L13.5 13.5L12 22L10.5 13.5L2 12L10.5 10.5L12 2Z"
                                    fill="#ffc107" opacity="0.6" />
                            </svg>
                            <svg width="30" height="30" viewBox="0 0 24 24" fill="none"
                                style="position: absolute; right: 40px; top: 10px; z-index: 1; animation: floatNode 3s infinite alternate;">
                                <circle cx="12" cy="12" r="8" stroke="#00BCD4" stroke-width="2" stroke-dasharray="2 2"
                                    fill="none" />
                            </svg>
                        </div>
                    </div>

                    <div class="workflow-circle">
                        <div class="workflow-curve-half"></div>
                        <div class="workflow-node node-1">
                            <div class="node-inner">STEP<br>01</div>
                        </div>
                        <div class="workflow-node node-2">
                            <div class="node-inner">STEP<br>02</div>
                        </div>
                        <div class="workflow-node node-3">
                            <div class="node-inner">STEP<br>03</div>
                        </div>
                    </div>
                </div>

            </div>
