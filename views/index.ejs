<%- include('partials/header') %>

    <!-- Hero Section -->
    <section class="hero">
        <div class="container" data-aos="fade-up">
            <h1 style="font-size: 3.5rem; margin-bottom: 20px;">Bring Your Story to Life With Professional Publishing
            </h1>
            <p style="font-size: 1.2rem; max-width: 800px; margin: 0 auto 40px; opacity: 0.9;">From ghostwriting to
                worldwide distribution, we provide end-to-end services to help you become a published author.</p>
            <div style="display: inline-flex; align-items: center; gap: 10px; background: rgba(255, 255, 255, 0.15); border: 1px solid rgba(255, 255, 255, 0.3); padding: 8px 18px; border-radius: 50px; margin-bottom: 25px; backdrop-filter: blur(5px);">
                <span style="background: var(--secondary-color); color: var(--primary-color); padding: 2px 10px; border-radius: 50px; font-size: 0.8rem; font-weight: 800;">NEW OFFER</span>
                <span style="font-size: 0.9rem; font-weight: 500;">Enjoy <strong style="color: var(--secondary-color);">40% OFF</strong> on all Publishing Packages!</span>
            </div>
            <div class="hero-btns">
                <a href="/services" class="btn btn-secondary">Explore Services</a>
                <a href="/contact" class="btn btn-primary" style="border: 2px solid white; margin-left: 15px;">Claim Your Offer</a>
            </div>
        </div>
    </section>

    <!-- Overview of Services -->
    <section class="services-overview">
        <div class="container">
            <div class="section-title" style="text-align: center; margin-bottom: 50px;">
                <h2 data-aos="fade-up">Our Expertise</h2>
                <p data-aos="fade-up" data-aos-delay="100">Tailored solutions for every aspiring author.</p>
            </div>
            <div class="services-grid"
                style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px;">
                <div class="service-card" data-aos="fade-up"
                    style="background: white; padding: 40px; border-radius: 15px; box-shadow: var(--shadow); transition: var(--transition);">
                    <div class="icon" style="font-size: 2.5rem; color: var(--secondary-color); margin-bottom: 20px;">✍️
                    </div>
                    <h3>Ghostwriting</h3>
                    <p>Expert writers to turn your ideas into a bestseller while you keep all the credit.</p>
                </div>
                <div class="service-card" data-aos="fade-up" data-aos-delay="100"
                    style="background: white; padding: 40px; border-radius: 15px; box-shadow: var(--shadow); transition: var(--transition);">
                    <div class="icon" style="font-size: 2.5rem; color: var(--secondary-color); margin-bottom: 20px;">📖
                    </div>
                    <h3>Book Publishing</h3>
                    <p>Complete print and digital distribution to Amazon, Barnes & Noble, and more.</p>
                </div>
                <div class="service-card" data-aos="fade-up" data-aos-delay="200"
                    style="background: white; padding: 40px; border-radius: 15px; box-shadow: var(--shadow); transition: var(--transition);">
                    <div class="icon" style="font-size: 2.5rem; color: var(--secondary-color); margin-bottom: 20px;">🎨
                    </div>
                    <h3>Cover Design</h3>
                    <p>Stunning, market-ready book covers designed to grab every reader's attention.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Publishing Process -->
    <section class="process" style="background-color: #f4f1ff;">
        <div class="container">
            <div class="section-title" style="text-align: center; margin-bottom: 60px;">
                <h2 data-aos="fade-up">The Path to Publication</h2>
                <p data-aos="fade-up" data-aos-delay="100">How we work together to launch your book.</p>
            </div>
            <div class="process-steps"
                style="display: flex; justify-content: space-around; flex-wrap: wrap; gap: 40px;">
                <div class="step" data-aos="zoom-in" style="text-align: center; max-width: 200px;">
                    <div class="step-number"
                        style="width: 60px; height: 60px; background: var(--primary-color); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; font-weight: bold; margin: 0 auto 20px;">
                        1</div>
                    <h4>Consultation</h4>
                    <p>We discuss your vision and goals.</p>
                </div>
                <div class="step" data-aos="zoom-in" data-aos-delay="100" style="text-align: center; max-width: 200px;">
                    <div class="step-number"
                        style="width: 60px; height: 60px; background: var(--primary-color); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; font-weight: bold; margin: 0 auto 20px;">
                        2</div>
                    <h4>Preparation</h4>
                    <p>Writing, editing, and designing process.</p>
                </div>
                <div class="step" data-aos="zoom-in" data-aos-delay="200" style="text-align: center; max-width: 200px;">
                    <div class="step-number"
                        style="width: 60px; height: 60px; background: var(--primary-color); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; font-weight: bold; margin: 0 auto 20px;">
                        3</div>
                    <h4>Production</h4>
                    <p>Formatting and final quality checks.</p>
                </div>
                <div class="step" data-aos="zoom-in" data-aos-delay="300" style="text-align: center; max-width: 200px;">
                    <div class="step-number"
                        style="width: 60px; height: 60px; background: var(--primary-color); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; font-weight: bold; margin: 0 auto 20px;">
                        4</div>
                    <h4>Launch</h4>
                    <p>Global distribution and marketing.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Premium Ghostwriting & Publishing Showcase -->
    <section class="premium-publishing" style="background-color: var(--white); padding: 110px 0 140px; position: relative; border-top: 1px solid rgba(0,0,0,0.05);">
        
        <div class="container">
            <div class="premium-grid" style="display: grid; grid-template-columns: 0.8fr 1.2fr; gap: 70px; align-items: center;">
                
                <!-- Left: Visual -->
                <div class="premium-visual" data-aos="fade-right" style="position: relative;">
                    <!-- Floating abstract effect behind image -->
                    <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 120%; height: 120%; background: radial-gradient(circle, rgba(212,175,55,0.15) 0%, rgba(0,0,0,0) 70%); z-index: 1;"></div>
                    
                    <img src="https://images.unsplash.com/photo-1512820790803-83ca734da794?auto=format&fit=crop&q=80&w=800" alt="Professional Book Publishing Portfolio" style="width: 100%; border-radius: 12px; box-shadow: 0 40px 80px rgba(61,44,94,0.15); z-index: 2; position: relative; border: 1px solid rgba(0,0,0,0.05);">
                </div>

                <!-- Right: Content -->
                <div class="premium-content" data-aos="fade-left">
                    <span style="display: inline-block; background: rgba(212, 175, 55, 0.1); color: var(--secondary-dark); padding: 6px 16px; border-radius: 50px; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase; font-size: 0.75rem; margin-bottom: 25px;">
                        Enterprise-Grade Publishing
                    </span>
                    
                    <h2 style="font-size: 3.5rem; font-family: 'Playfair Display', serif; line-height: 1.15; margin: 0 0 25px; color: var(--primary-color);">
                        Masterpiece Architecture. <br><span style="color: var(--secondary-color); font-style: italic;">Built Around You.</span>
                    </h2>
                    
                    <p style="font-size: 1.15rem; color: #555; line-height: 1.8; margin-bottom: 45px; font-weight: 400;">
                        We fiercely reject the industry norm of cookie-cutter templates and outsourced mediocrity. At Infranex, we synthesize your raw vision with our relentless editorial standard to engineer books that dominate their genre. Authentic voice. Lethal market positioning. Total author sovereignty.
                    </p>
                    
                    <!-- Features Grid -->
                    <div class="feature-list" style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
                        <div class="p-feature" style="display: flex; align-items: flex-start; gap: 18px;">
                            <div style="background: rgba(212, 175, 55, 0.15); width: 45px; height: 45px; border-radius: 10px; display: flex; align-items: center; justify-content: center; color: var(--secondary-dark); font-size: 1.2rem; flex-shrink: 0;">
                                <i class="fas fa-brain"></i>
                            </div>
                            <div>
                                <h4 style="font-size: 1.05rem; margin-bottom: 6px; color: var(--primary-color); font-weight: 700;">1-on-1 Synergy</h4>
                                <p style="font-size: 0.9rem; color: #666; line-height: 1.5;">Direct collaboration with elite literary architects.</p>
                            </div>
                        </div>
                        
                        <div class="p-feature" style="display: flex; align-items: flex-start; gap: 18px;">
                            <div style="background: rgba(212, 175, 55, 0.15); width: 45px; height: 45px; border-radius: 10px; display: flex; align-items: center; justify-content: center; color: var(--secondary-dark); font-size: 1.2rem; flex-shrink: 0;">
                                <i class="fas fa-feather-alt"></i>
                            </div>
                            <div>
                                <h4 style="font-size: 1.05rem; margin-bottom: 6px; color: var(--primary-color); font-weight: 700;">Authentic Voice</h4>
                                <p style="font-size: 0.9rem; color: #666; line-height: 1.5;">Ghostwriting that intimately mirrors your tone.</p>
                            </div>
                        </div>
                        
                        <div class="p-feature" style="display: flex; align-items: flex-start; gap: 18px;">
                            <div style="background: rgba(212, 175, 55, 0.15); width: 45px; height: 45px; border-radius: 10px; display: flex; align-items: center; justify-content: center; color: var(--secondary-dark); font-size: 1.2rem; flex-shrink: 0;">
                                <i class="fas fa-drafting-compass"></i>
                            </div>
                            <div>
                                <h4 style="font-size: 1.05rem; margin-bottom: 6px; color: var(--primary-color); font-weight: 700;">Immersive Layouts</h4>
                                <p style="font-size: 0.9rem; color: #666; line-height: 1.5;">Bespoke interior and exterior custom designs.</p>
                            </div>
                        </div>
                        
                        <div class="p-feature" style="display: flex; align-items: flex-start; gap: 18px;">
                            <div style="background: rgba(212, 175, 55, 0.15); width: 45px; height: 45px; border-radius: 10px; display: flex; align-items: center; justify-content: center; color: var(--secondary-dark); font-size: 1.2rem; flex-shrink: 0;">
                                <i class="fas fa-rocket"></i>
                            </div>
                            <div>
                                <h4 style="font-size: 1.05rem; margin-bottom: 6px; color: var(--primary-color); font-weight: 700;">SEO Optimization</h4>
                                <p style="font-size: 0.9rem; color: #666; line-height: 1.5;">Maximum visibility across global retail marketplaces.</p>
                            </div>
                        </div>
                    </div>
                    
                </div>
            </div>
        </div>
        
        <style>
            @media (max-width: 1024px) {
                .premium-grid { grid-template-columns: 1fr !important; gap: 50px !important; }
                .premium-visual { order: -1; max-width: 600px; margin: 0 auto; }
            }
            @media (max-width: 768px) {
                .premium-publishing h2 { font-size: 2.3rem !important; }
                .premium-publishing p { font-size: 1.05rem !important; }
            }
            @media (max-width: 500px) {
                .premium-publishing .feature-list { grid-template-columns: 1fr !important; gap: 20px !important; }
            }
        </style>
    </section>


    <%- include('partials/footer') %>