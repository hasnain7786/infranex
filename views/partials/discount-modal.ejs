<!-- Discount Popup Modal -->
<div id="discountModal" class="modal-overlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 9999; justify-content: center; align-items: center; backdrop-filter: blur(5px); opacity: 0; transition: opacity 0.3s ease;">
    <div class="modal-content" style="background: white; width: 90%; max-width: 500px; border-radius: 15px; position: relative; overflow: hidden; box-shadow: 0 25px 50px rgba(0,0,0,0.5); transform: translateY(20px); transition: transform 0.3s ease;">
        
        <!-- Close Button -->
        <button onclick="closeDiscountModal()" style="position: absolute; top: 15px; right: 15px; background: rgba(0,0,0,0.1); border: none; width: 30px; height: 30px; border-radius: 50%; font-size: 1.2rem; cursor: pointer; display: flex; align-items: center; justify-content: center; z-index: 10;">
            <i class="fas fa-times"></i>
        </button>

        <!-- Header -->
        <div style="background: linear-gradient(135deg, var(--primary-color), var(--primary-light)); padding: 30px 20px 20px; text-align: center; color: white;">
            <span style="background: var(--secondary-color); color: var(--primary-color); padding: 4px 12px; border-radius: 50px; font-size: 0.75rem; font-weight: 800; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 10px; display: inline-block;">Limited Time Offer</span>
            <h2 style="font-size: 2rem; margin: 10px 0 5px; font-weight: 800;">Up to 60% Off!</h2>
            <p style="font-size: 0.95rem; opacity: 0.9; margin: 0;">On Ghostwriting, Editing & Publication</p>
        </div>

        <!-- Timer -->
        <div style="background: #f8f9fa; padding: 15px; text-align: center; border-bottom: 1px solid #eee;">
            <p style="font-size: 0.8rem; font-weight: 700; color: #555; text-transform: uppercase; margin-bottom: 8px;">Offer Expires In:</p>
            <div style="display: flex; justify-content: center; gap: 15px; color: var(--primary-color);">
                <div style="text-align: center;">
                    <span id="modal-hours" style="font-size: 1.5rem; font-weight: 800; display: block; line-height: 1;">23</span>
                    <span style="font-size: 0.65rem; font-weight: 600;">HOURS</span>
                </div>
                <span style="font-size: 1.5rem; font-weight: 800;">:</span>
                <div style="text-align: center;">
                    <span id="modal-minutes" style="font-size: 1.5rem; font-weight: 800; display: block; line-height: 1;">59</span>
                    <span style="font-size: 0.65rem; font-weight: 600;">MINS</span>
                </div>
                <span style="font-size: 1.5rem; font-weight: 800;">:</span>
                <div style="text-align: center;">
                    <span id="modal-seconds" style="font-size: 1.5rem; font-weight: 800; display: block; line-height: 1;">59</span>
                    <span style="font-size: 0.65rem; font-weight: 600;">SECS</span>
                </div>
            </div>
        </div>

        <!-- Form -->
        <form action="/leads" method="POST" style="padding: 25px;">
            <input type="hidden" name="source" value="contact"> <!-- Using 'contact' as source so it redirects safely -->
            <input type="hidden" name="package" value="60% Discount Promo">

            <div style="margin-bottom: 15px;">
                <input type="text" name="name" placeholder="Enter your name *" required style="width: 100%; padding: 12px 15px; border: 1px solid #ddd; border-radius: 8px; font-family: 'Inter', sans-serif;">
            </div>
            
            <div style="margin-bottom: 15px;">
                <input type="tel" name="phone" placeholder="Phone Number *" required style="width: 100%; padding: 12px 15px; border: 1px solid #ddd; border-radius: 8px; font-family: 'Inter', sans-serif;">
            </div>
            
            <div style="margin-bottom: 15px;">
                <input type="email" name="email" placeholder="Enter email here *" required style="width: 100%; padding: 12px 15px; border: 1px solid #ddd; border-radius: 8px; font-family: 'Inter', sans-serif;">
            </div>

            <!-- Message Textarea -->
            <div style="margin-bottom: 20px;">
                <textarea name="message" placeholder="Enter a brief description about your book" required style="width: 100%; padding: 12px 15px; border: 1px solid #ddd; border-radius: 8px; font-family: 'Inter', sans-serif; resize: vertical; min-height: 80px;"></textarea>
            </div>
            
            <button type="submit" style="width: 100%; background: linear-gradient(135deg, var(--secondary-color), var(--secondary-dark)); color: white; border: none; padding: 15px; border-radius: 8px; font-size: 1.1rem; font-weight: 700; cursor: pointer; text-transform: uppercase; box-shadow: 0 10px 20px rgba(212,175,55,0.3);">
                Claim Discount <i class="fas fa-arrow-right" style="margin-left: 5px;"></i>
            </button>
        </form>
    </div>
</div>

<script>
    // Modal Logic
    const discountModal = document.getElementById('discountModal');
    const modalContent = discountModal.querySelector('.modal-content');
    
    function openDiscountModal() {
        discountModal.style.display = 'flex';
        setTimeout(() => {
            discountModal.style.opacity = '1';
            modalContent.style.transform = 'translateY(0)';
        }, 10);
    }
    
    function closeDiscountModal() {
        discountModal.style.opacity = '0';
        modalContent.style.transform = 'translateY(20px)';
        setTimeout(() => {
            discountModal.style.display = 'none';
        }, 300);
    }
    
    // Auto-popup after 2.5 seconds if it's the first time
    window.addEventListener('DOMContentLoaded', () => {
        if(!sessionStorage.getItem('discountSeen')) {
            setTimeout(() => {
                openDiscountModal();
                sessionStorage.setItem('discountSeen', 'true');
            }, 2500);
        }
    });

    // Countdown Timer Logic
    function startCountdown() {
        // Set fixed end time to 23:59:59 from now
        let end = new Date().getTime() + (23 * 60 * 60 * 1000) + (59 * 60 * 1000) + (59 * 1000);
        
        setInterval(function() {
            let now = new Date().getTime();
            let distance = end - now;
            
            // Time calculations for days, hours, minutes and seconds
            let hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            let minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
            let seconds = Math.floor((distance % (1000 * 60)) / 1000);
            
            // Format numbers
            hours = hours < 10 ? "0" + hours : hours;
            minutes = minutes < 10 ? "0" + minutes : minutes;
            seconds = seconds < 10 ? "0" + seconds : seconds;
            
            // Update Modal Timer
            let mH = document.getElementById("modal-hours");
            if(mH) {
                mH.innerHTML = hours;
                document.getElementById("modal-minutes").innerHTML = minutes;
                document.getElementById("modal-seconds").innerHTML = seconds;
            }

            // Update Hero Timer (if exists)
            let hH = document.getElementById("hero-hours");
            if(hH) {
                // For Hero we want a specific look from the image (like 1 hr 30 mins)
                // Let's just make it sync with the countdown but subtract hours maybe? 
                // The image had 1:30:15 so let's just make it count from 11:59:59 for urgency.
                hH.innerHTML = parseInt(hours) > 12 ? (parseInt(hours) - 12) : hours;
                document.getElementById("hero-minutes").innerHTML = minutes;
                document.getElementById("hero-seconds").innerHTML = seconds;
            }
            
            if (distance < 0) {
                end = new Date().getTime() + (23 * 60 * 60 * 1000); // Reset
            }
        }, 1000);
    }
    
    startCountdown();
</script>
