<footer class="main-footer <%= (typeof title !== 'undefined' && title.includes('Home')) ? '' : 'footer-no-cta' %>">
    <% if (typeof title !=='undefined' && title.includes('Home')) { %>
        <div class="footer-cta-wrapper">
            <div class="container">
                <div class="footer-cta" data-aos="fade-up">
                    <div class="footer-cta-text">
                        <h2>Ready to Become an Author?</h2>
                        <p>Take the first step towards your publishing dream today.</p>
                    </div>
                    <div class="footer-cta-btn">
                        <a href="/contact" class="btn btn-secondary">Get a Free Consultation</a>
                    </div>
                </div>
            </div>
        </div>
        <% } %>
                <div class="footer-content" style="display: grid; grid-template-columns: 1.5fr 0.8fr 0.8fr 1fr 1.5fr; gap: 20px; padding-bottom: 50px; border-bottom: 1px solid rgba(255,255,255,0.1);">
                    <!-- Column 1: Brand Info (Left Aligned) -->
                    <div class="footer-info" style="text-align: left;">
                        <h3 style="font-family: 'Playfair Display', serif; font-size: 1.8rem; font-weight: 800; color: #fff; margin-bottom: 20px;">
                            Infranex Publishers
                        </h3>
                        <p style="font-size: 0.95rem; color: rgba(255,255,255,0.75); line-height: 1.6; margin-bottom: 20px; max-width: 300px;">
                            Empowering authors to share their stories with the world through professional publishing and premium Audio Book services.
                        </p>
                        <div class="social-links-container" style="display: flex; gap: 20px;">
                            <a href="https://www.facebook.com/profile.php?id=61588078614477&mibextid=wwXIfr" target="_blank" style="color: #fff; font-size: 1.3rem;"><i class="fab fa-facebook-f"></i></a>
                            <a href="https://www.instagram.com/ms_infranex?igsh=MXZhYWlmdzdpZTR4Mg%3D%3D&utm_source=qr" target="_blank" style="color: #fff; font-size: 1.3rem;"><i class="fab fa-instagram"></i></a>
                        </div>
                    </div>

                    <!-- Column 2: Quick Links -->
                    <div class="footer-links" style="padding-top: 10px;">
                        <h4 style="color: #fff; font-size: 1.1rem; font-weight: 700; margin-bottom: 25px; position: relative;">Quick Links</h4>
                        <ul style="list-style: none; padding: 0;">
                            <li style="margin-bottom: 12px;"><a href="/" style="color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.95rem;">Home</a></li>
                            <li style="margin-bottom: 12px;"><a href="/about" style="color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.95rem;">About Us</a></li>
                            <li style="margin-bottom: 12px;"><a href="/services" style="color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.95rem;">Services</a></li>
                            <li style="margin-bottom: 12px;"><a href="/pricing" style="color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.95rem;">Pricing</a></li>
                            <li style="margin-bottom: 12px;"><a href="/articles" style="color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.95rem;">Articles</a></li>
                        </ul>
                    </div>

                    <!-- Column 3: Top Services -->
                    <div class="footer-links" style="padding-top: 10px;">
                        <h4 style="color: #fff; font-size: 1.1rem; font-weight: 700; margin-bottom: 25px; position: relative;">Top Services</h4>
                        <ul style="list-style: none; padding: 0;">
                            <li style="margin-bottom: 12px;"><a href="/services" style="color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.95rem;">Ghostwriting</a></li>
                            <li style="margin-bottom: 12px;"><a href="/services" style="color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.95rem;">Book Editing</a></li>
                            <li style="margin-bottom: 12px;"><a href="/audiobook-services" style="color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.95rem;">Audio Books</a></li>
                            <li style="margin-bottom: 12px;"><a href="/services" style="color: rgba(255,255,255,0.75); text-decoration: none; font-size: 0.95rem;">Cover Design</a></li>
                        </ul>
                    </div>

                    <!-- Column 4: Contact Us -->
                    <div class="footer-contact" style="padding-top: 10px;">
                        <h4 style="color: #fff; font-size: 1.1rem; font-weight: 700; margin-bottom: 25px; position: relative;">Contact Us</h4>
                        <ul style="list-style: none; padding: 0;">
                            <li style="display: flex; gap: 12px; margin-bottom: 15px; color: rgba(255,255,255,0.8); font-size: 0.9rem;">
                                <i class="fas fa-map-marker-alt" style="color: #dcb348; margin-top: 4px;"></i>
                                <span>6545 Market Ave. North Canton, OH</span>
                            </li>
                            <li style="display: flex; gap: 12px; margin-bottom: 15px; color: rgba(255,255,255,0.8); font-size: 0.9rem;">
                                <i class="fas fa-envelope" style="color: #dcb348; margin-top: 4px;"></i>
                                <span>Team@infranexpublishers.com</span>
                            </li>
                            <li style="display: flex; gap: 12px; color: rgba(255,255,255,0.8); font-size: 0.9rem;">
                                <i class="fas fa-phone-alt" style="color: #dcb348; margin-top: 4px;"></i>
                                <span>+1 325 648 0085</span>
                            </li>
                        </ul>
                    </div>

                    <!-- Column 5: Newsletter (Right Aligned) -->
                    <div class="footer-newsletter" style="text-align: right; padding-top: 10px;">
                        <h4 style="color: #fff; font-size: 1.2rem; font-weight: 700; margin-bottom: 25px; position: relative;">Stay Informed</h4>
                        <p style="font-size: 0.9rem; color: rgba(255,255,255,0.7); margin-bottom: 20px;">Get publishing tips and exclusive offers.</p>
                        <% if (typeof query !== 'undefined' && query.subscribed === 'true') { %>
                            <div style="background: rgba(220,179,72,0.2); padding: 12px; border-radius: 8px; color: #dcb348; font-size: 0.9rem; display: inline-block; width: 100%;">
                                <i class="fas fa-check-circle"></i> Subscribed!
                            </div>
                        <% } else { %>
                        <form action="/newsletter" method="POST" style="display: flex; flex-direction: column; gap: 12px; max-width: 280px; margin-left: auto;">
                            <input type="text" name="name" placeholder="Name" required style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); padding: 12px 15px; border-radius: 8px; color: #fff; font-size: 0.9rem;">
                            <input type="email" name="email" placeholder="Email Address" required style="background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); padding: 12px 15px; border-radius: 8px; color: #fff; font-size: 0.9rem;">
                            <button type="submit" style="background: #dcb348; color: #3d2c5e; border: none; padding: 12px; border-radius: 8px; font-weight: 800; cursor: pointer; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 1px; transition: 0.3s;">Subscribe</button>
                        </form>
                        <% } %>
                    </div>
                </div>

                <div class="footer-bottom" style="padding-top: 40px; text-align: center;">
                    <div class="footer-bottom-flex" style="display: flex; flex-direction: column; align-items: center; gap: 15px;">
                        <p style="margin: 0; font-size: 0.9rem; color: rgba(255,255,255,0.6);">&copy; 2026 Infranex Publishers. All Rights Reserved.</p>
                        <div class="legal-links" style="display: flex; gap: 25px;">
                            <a href="/privacy-policy" style="color: rgba(255,255,255,0.6); text-decoration: none; font-size: 0.9rem; transition: 0.3s;">Privacy Policy</a>
                            <a href="/terms-of-service" style="color: rgba(255,255,255,0.6); text-decoration: none; font-size: 0.9rem; transition: 0.3s;">Terms of Service</a>
                            <a href="/disclaimer" style="color: rgba(255,255,255,0.6); text-decoration: none; font-size: 0.9rem; transition: 0.3s;">Disclaimer</a>
                        </div>
                    </div>
                </div>
            </div>
</footer>

<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>
    AOS.init({
        duration: 1000,
        once: true,
        easing: 'ease-out-cubic'
    });
</script>
<script src="/js/main.js"></script>
<!-- Include Discount Modal -->
<%- include('discount-modal') %>

