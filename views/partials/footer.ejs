<footer class="main-footer <%= (typeof title !== 'undefined' && title.includes('Home')) ? '' : 'footer-no-cta' %>">
    <% if (typeof title !=='undefined' && title.includes('Home')) { %>
        <div class="footer-cta-wrapper">
            <div class="container">
                <div class="footer-cta" data-aos="fade-up">
                    <div class="footer-cta-text">
                        <h2>Ready to Become an Author?</h2>
                        <p>Take the first step towards your publishing dream today.</p>
                    </div>
                    <div class="footer-cta-btn">
                        <a href="/contact" class="btn btn-secondary">Get a Free Consultation</a>
                    </div>
                </div>
            </div>
        </div>
        <% } %>
            <div class="container">
                <div class="footer-content">
                    <div class="footer-info">
                        <h3
                            style="font-family: 'Playfair Display', serif; font-size: 1.8rem; font-weight: 800; color: #fff; margin-bottom: 15px; letter-spacing: 0.5px; opacity: 0.95;">
                            Infranex Publishers
                        </h3>
                        <p class="footer-desc">
                            Empowering authors to share their stories with the world through professional publishing and
                            premium
                            Audio Book services. Your vision, our expertise.
                        </p>
                        <div class="social-links-container">
                            <a href="https://www.facebook.com/profile.php?id=61588078614477&mibextid=wwXIfr"
                                target="_blank" class="social-link facebook" aria-label="Facebook">
                                <i class="fab fa-facebook-f"></i>
                            </a>
                            <a href="https://www.instagram.com/ms_infranex?igsh=MXZhYWlmdzdpZTR4Mg%3D%3D&utm_source=qr"
                                target="_blank" class="social-link instagram" aria-label="Instagram">
                                <i class="fab fa-instagram"></i>
                            </a>
                        </div>
                    </div>

                    <div class="footer-links-group">
                        <div class="footer-links">
                            <h4>Quick Links</h4>
                            <ul>
                                <li><a href="/"><i class="fas fa-chevron-right"></i> Home</a></li>
                                <li><a href="/about"><i class="fas fa-chevron-right"></i> About Us</a></li>
                                <li><a href="/services"><i class="fas fa-chevron-right"></i> Services</a></li>
                                <li><a href="/audiobook-services"><i class="fas fa-chevron-right"></i> Audio Book
                                        Services</a>
                                </li>
                                <li><a href="/pricing"><i class="fas fa-chevron-right"></i> Pricing</a></li>
                                <li><a href="/articles"><i class="fas fa-chevron-right"></i> Articles</a></li>
                            </ul>
                        </div>
                        <div class="footer-links">
                            <h4>Top Services</h4>
                            <ul>
                                <li><a href="/services"><i class="fas fa-chevron-right"></i> Ghostwriting</a></li>
                                <li><a href="/services"><i class="fas fa-chevron-right"></i> Book Editing</a></li>
                                <li><a href="/audiobook-services"><i class="fas fa-chevron-right"></i> Audio Book
                                        Services</a></li>
                                <li><a href="/services"><i class="fas fa-chevron-right"></i> Cover Design</a></li>
                                <li><a href="/contact"><i class="fas fa-chevron-right"></i> Consultation</a></li>
                            </ul>
                        </div>
                    </div>

                    <div class="footer-contact">
                        <h4>Contact Us</h4>
                        <ul class="contact-info-list">
                            <li>
                                <i class="fas fa-map-marker-alt"></i>
                                <span>6545 Market Ave. North STE 100 North Canton, OH 44721</span>
                            </li>
                            <li>
                                <i class="fas fa-envelope"></i>
                                <span><a
                                        href="mailto:Team@infranexpublishers.com">Team@infranexpublishers.com</a></span>
                            </li>
                            <li>
                                <i class="fas fa-phone-alt"></i>
                                <span>+1 325 648 0085</span>
                            </li>
                            <li>
                                <i class="far fa-clock"></i>
                                <span>Mon - Fri, 9AM - 6PM</span>
                            </li>
                        </ul>
                    </div>

                    <!-- Newsletter Signup -->
                    <div class="footer-newsletter">
                        <h4>Stay Informed</h4>
                        <p>Get expert publishing tips, industry insights, and exclusive offers delivered to your inbox.</p>
                        <% if (typeof query !== 'undefined' && query.subscribed === 'true') { %>
                            <div style="background: rgba(220,179,72,0.15); border: 1px solid rgba(220,179,72,0.3); border-radius: 8px; padding: 14px 18px; color: #dcb348; font-weight: 600; font-size: 0.9rem;">
                                <i class="fas fa-check-circle"></i> Thank you for subscribing!
                            </div>
                        <% } else { %>
                        <form class="newsletter-form" action="/newsletter" method="POST">
                            <input
                                type="text"
                                name="name"
                                placeholder="Your Name"
                                class="newsletter-input"
                                required
                            />
                            <input
                                type="email"
                                name="email"
                                placeholder="Your Email Address"
                                class="newsletter-input"
                                required
                            />
                            <button type="submit" class="newsletter-btn">
                                <i class="fas fa-paper-plane"></i>&nbsp; Subscribe Now
                            </button>
                        </form>
                        <% } %>
                        <p class="newsletter-trust">
                            <i class="fas fa-lock"></i>
                            We respect your privacy. No spam, unsubscribe anytime.
                        </p>
                    </div>

                </div>
            </div>

                <div class="footer-bottom">
                    <div class="footer-bottom-flex">
                        <p>&copy; 2026 Infranex Publishers. All Rights Reserved.</p>
                        <div class="legal-links">
                            <a href="/privacy-policy">Privacy Policy</a>
                            <a href="/terms-of-service">Terms of Service</a>
                            <a href="/disclaimer">Disclaimer</a>
                        </div>
                    </div>
                </div>
            </div>
</footer>

<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>
    AOS.init({
        duration: 1000,
        once: true,
        easing: 'ease-out-cubic'
    });
</script>
<script src="/js/main.js"></script>
