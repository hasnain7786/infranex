<footer class="main-footer <%= (typeof title !== 'undefined' && title.includes('Home')) ? '' : 'footer-no-cta' %>">
    <% if (typeof title !=='undefined' && title.includes('Home')) { %>
        <div class="footer-cta-wrapper">
            <div class="container">
                <div class="footer-cta" data-aos="fade-up">
                    <div class="footer-cta-text">
                        <h2>Ready to Become an Author?</h2>
                        <p>Take the first step towards your publishing dream today.</p>
                    </div>
                    <div class="footer-cta-btn">
                        <a href="/contact" class="btn btn-secondary">Get a Free Consultation</a>
                    </div>
                </div>
            </div>
        </div>
        <% } %>
            <div class="container">
                <div class="footer-content">
                    <!-- Column 1: Brand Info -->
                    <div class="footer-info">
                        <h3 style="font-family: 'Playfair Display', serif; font-size: 1.8rem; font-weight: 800; color: #fff; margin-bottom: 15px;">
                            Infranex Publishers
                        </h3>
                        <p class="footer-desc">
                            Empowering authors to share their stories with the world through professional publishing and premium Audio Book services. Your vision, our expertise.
                        </p>
                        <div class="social-links-container" style="display: flex; gap: 15px;">
                            <a href="https://www.facebook.com/profile.php?id=61588078614477&mibextid=wwXIfr" target="_blank" style="color: #fff; font-size: 1.2rem;"><i class="fab fa-facebook-f"></i></a>
                            <a href="https://www.instagram.com/ms_infranex?igsh=MXZhYWlmdzdpZTR4Mg%3D%3D&utm_source=qr" target="_blank" style="color: #fff; font-size: 1.2rem;"><i class="fab fa-instagram"></i></a>
                        </div>
                    </div>

                    <!-- Column 2: Quick Links -->
                    <div class="footer-links">
                        <h4>Quick Links</h4>
                        <ul>
                            <li><a href="/">Home</a></li>
                            <li><a href="/about">About Us</a></li>
                            <li><a href="/services">Services</a></li>
                            <li><a href="/pricing">Pricing</a></li>
                            <li><a href="/articles">Articles</a></li>
                        </ul>
                    </div>

                    <!-- Column 3: Contact Info -->
                    <div class="footer-contact">
                        <h4>Contact Us</h4>
                        <ul class="contact-info-list">
                            <li><i class="fas fa-map-marker-alt"></i> <span>6545 Market Ave. North STE 100 North Canton, OH 44721</span></li>
                            <li><i class="fas fa-envelope"></i> <span>Team@infranexpublishers.com</span></li>
                            <li><i class="fas fa-phone-alt"></i> <span>+1 325 648 0085</span></li>
                        </ul>
                    </div>

                    <!-- Column 4: Newsletter -->
                    <div class="footer-newsletter">
                        <h4>Stay Informed</h4>
                        <p style="font-size: 0.85rem; color: rgba(255,255,255,0.7); margin-bottom: 15px;">Get publishing tips and exclusive offers.</p>
                        <% if (typeof query !== 'undefined' && query.subscribed === 'true') { %>
                            <div style="background: rgba(220,179,72,0.2); padding: 10px; border-radius: 5px; color: #dcb348; font-size: 0.8rem;">
                                <i class="fas fa-check-circle"></i> Subscribed!
                            </div>
                        <% } else { %>
                        <form class="newsletter-form" action="/newsletter" method="POST">
                            <input type="text" name="name" placeholder="Name" class="newsletter-input" required style="margin-bottom: 8px;">
                            <input type="email" name="email" placeholder="Email" class="newsletter-input" required style="margin-bottom: 8px;">
                            <button type="submit" class="newsletter-btn">Subscribe</button>
                        </form>
                        <% } %>
                    </div>
                </div>
            </div>

                <div class="footer-bottom">
                    <div class="footer-bottom-flex">
                        <p>&copy; 2026 Infranex Publishers. All Rights Reserved.</p>
                        <div class="legal-links">
                            <a href="/privacy-policy">Privacy Policy</a>
                            <a href="/terms-of-service">Terms of Service</a>
                            <a href="/disclaimer">Disclaimer</a>
                        </div>
                    </div>
                </div>
            </div>
</footer>

<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>
    AOS.init({
        duration: 1000,
        once: true,
        easing: 'ease-out-cubic'
    });
</script>
<script src="/js/main.js"></script>
<!-- Include Discount Modal -->
<%- include('discount-modal') %>

