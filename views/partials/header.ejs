<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="google-site-verification" content="s-kkOx8x4FCPBxFEKNj73AvL9ejFNCDNhRoN7K1B4QE" />
    <title>
        <%= title %>
    </title>
    <link rel="icon" type="image/svg+xml" href="/images/favicon.svg">
    <link rel="shortcut icon" href="/images/favicon.svg">
    <link rel="stylesheet" href="/css/style.css">
    <!-- AOS for scroll animations -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body>
    <!-- Top Contact Bar -->
    <div style="background-color: var(--primary-color); color: white; padding: 8px 0; border-bottom: 2px solid var(--secondary-color); font-size: 0.85rem; letter-spacing: 0.5px;">
        <div class="container" style="display: flex; justify-content: space-between; align-items: center;">
            <div style="display: flex; gap: 25px;">
                <a href="tel:+17402999194" style="color: white; font-weight: 600; transition: opacity 0.3s; opacity: 0.95;">
                    <i class="fas fa-phone-alt" style="color: var(--secondary-color); margin-right: 6px;"></i> +1 (740) 299-9194
                </a>
                <a href="mailto:team@infranexpublishers.com" class="hide-mobile" style="color: white; opacity: 0.85; transition: opacity 0.3s;">
                    <i class="fas fa-envelope" style="color: var(--secondary-color); margin-right: 6px;"></i> team@infranexpublishers.com
                </a>
            </div>
            <div>
                <a href="javascript:void(Tawk_API.toggle())" class="top-chat-btn" style="color: var(--secondary-color); font-weight: 800; text-transform: uppercase; font-size: 0.8rem;">
                    <i class="fas fa-comment-dots" style="margin-right: 4px;"></i> Live Chat
                </a>
            </div>
        </div>
    </div>
    
    <style>
        .top-chat-btn:hover { opacity: 0.8; }
        @media (max-width: 768px) {
            .hide-mobile { display: none !important; }
        }
    </style>

    <header>
        <div class="container nav-container">
            <a href="/" class="logo">
                <img src="/images/logo.svg" alt="Infranex Publishers Logo" class="logo-image">
            </a>
            <ul class="nav-links" id="navLinks">
                <li><a href="/">Home</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/services">Services</a></li>
                <li><a href="/audiobook-services">Audio Book Services</a></li>
                <li><a href="/pricing">Pricing</a></li>
                <li><a href="/articles">Articles</a></li>
                <li><a href="/testimonials">Portfolio</a></li>
                <li><a href="/contact" class="btn btn-primary nav-btn">Get Started</a></li>
            </ul>
            <div class="mobile-menu-btn" id="mobileMenuBtn">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </div>
    </header>