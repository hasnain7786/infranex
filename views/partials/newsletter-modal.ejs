
<div id="newsletterModal" class="modal" style="display: none; position: fixed; z-index: 10001; left: 0; top: 0; width: 100%; height: 100%; overflow: auto; background-color: rgba(0,0,0,0.6); backdrop-filter: blur(5px);">
    <div class="modal-content" style="background-color: #fdfcf0; margin: 10% auto; padding: 40px; border: 1px solid #dcb348; width: 90%; max-width: 500px; border-radius: 15px; position: relative; box-shadow: 0 20px 40px rgba(0,0,0,0.2);">
        <span onclick="closeNewsletterModal()" style="color: #aaa; position: absolute; right: 20px; top: 15px; font-size: 28px; font-weight: bold; cursor: pointer;">&times;</span>
        
        <div style="text-align: center;">
            <div style="width: 70px; height: 70px; background: #3d2c5e; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; color: #dcb348; font-size: 1.8rem;">
                <i class="fas fa-envelope-open-text"></i>
            </div>
            <h2 style="font-family: 'Playfair Display', serif; color: #3d2c5e; margin-bottom: 10px; font-weight: 800;">Stay Informed!</h2>
            <p style="color: #666; font-size: 1rem; margin-bottom: 30px;">Subscribe to our newsletter for exclusive publishing tips, industry insights, and special offers.</p>
            
            <form action="/newsletter" method="POST" style="display: flex; flex-direction: column; gap: 15px;">
                <input type="text" name="name" placeholder="Your Full Name" required style="padding: 14px; border-radius: 8px; border: 1px solid #ddd; font-size: 1rem; background: #fff;">
                <input type="email" name="email" placeholder="Your Email Address" required style="padding: 14px; border-radius: 8px; border: 1px solid #ddd; font-size: 1rem; background: #fff;">
                <button type="submit" style="background: linear-gradient(135deg, #dcb348, #c59b35); color: #3d2c5e; border: none; padding: 15px; border-radius: 8px; font-weight: 800; font-size: 1rem; cursor: pointer; text-transform: uppercase; letter-spacing: 1px; transition: 0.3s; margin-top: 10px;">Subscribe Now</button>
            </form>
            <p style="font-size: 0.8rem; color: #999; margin-top: 20px;"><i class="fas fa-lock"></i> We respect your privacy. Unsubscribe anytime.</p>
        </div>
    </div>
</div>

<script>
function openNewsletterModal() {
    document.getElementById('newsletterModal').style.display = 'block';
}

function closeNewsletterModal() {
    document.getElementById('newsletterModal').style.display = 'none';
}

// Close when clicking outside
window.onclick = function(event) {
    var modal = document.getElementById('newsletterModal');
    if (event.target == modal) {
        modal.style.display = "none";
    }
}
</script>
