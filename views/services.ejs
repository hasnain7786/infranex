    <style>
        /* ── Section wrapper ── */
        .flip-section {
            padding: 80px 0;
            background: var(--bg-color);
        }

        /* ── Grid ── */
        .flip-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 32px;
        }

        @media (max-width: 900px) {
            .flip-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 580px) {
            .flip-grid {
                grid-template-columns: 1fr;
            }
        }

        /* ── Card wrapper — sets 3D perspective ── */
        .flip-card {
            height: 340px;
            perspective: 1200px;
            cursor: pointer;
        }

        /* ── Inner wrapper that actually rotates ── */
        .flip-card__inner {
            position: relative;
            width: 100%;
            height: 100%;
            transition: transform 0.75s cubic-bezier(0.4, 0.2, 0.2, 1);
            transform-style: preserve-3d;
        }

        .flip-card:hover .flip-card__inner {
            transform: rotateY(180deg);
        }

        /* ── Shared face styles ── */
        .flip-card__front,
        .flip-card__back {
            position: absolute;
            inset: 0;
            border-radius: 20px;
            backface-visibility: hidden;
            -webkit-backface-visibility: hidden;
            overflow: hidden;
        }

        /* ── FRONT face ── */
        .flip-card__front {
            background: var(--fc-grad);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 18px;
            box-shadow: 0 16px 48px rgba(0, 0, 0, 0.22);
        }

        /* Subtle shimmer effect on front */
        .flip-card__front::after {
            content: '';
            position: absolute;
            top: -60%;
            left: -60%;
            width: 220%;
            height: 220%;
            background: radial-gradient(ellipse at center, rgba(255, 255, 255, 0.07) 0%, transparent 70%);
            pointer-events: none;
        }

        .flip-card__icon {
            font-size: 3.6rem;
            filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.3));
            animation: float 3s ease-in-out infinite;
        }

        @keyframes float {

            0%,
            100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-8px);
            }
        }

        .flip-card__title {
            font-family: 'Playfair Display', serif;
            font-size: 1.45rem;
            color: #fff;
            font-weight: 700;
            text-align: center;
            margin: 0;
            text-shadow: 0 2px 12px rgba(0, 0, 0, 0.3);
        }

        .flip-card__hint {
            font-size: 0.72rem;
            color: rgba(255, 255, 255, 0.55);
            letter-spacing: 1.2px;
            text-transform: uppercase;
        }

        /* ── BACK face ── */
        .flip-card__back {
            background: #fff;
            transform: rotateY(180deg);
            display: flex;
            flex-direction: column;
            padding: 28px 26px 24px;
            box-shadow: 0 16px 48px rgba(61, 44, 94, 0.14);
            border: 1.5px solid #eee;
        }

        .flip-card__back-icon {
            font-size: 1.6rem;
            margin-bottom: 6px;
        }

        .flip-card__back-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.15rem;
            color: var(--primary-color);
            margin-bottom: 10px;
        }

        .flip-card__desc {
            font-size: 0.88rem;
            color: var(--text-muted);
            line-height: 1.6;
            margin-bottom: 14px;
            flex-grow: 1;
        }

        .flip-card__list {
            list-style: none;
            padding: 0;
            margin: 0 0 18px;
        }

        .flip-card__list li {
            font-size: 0.84rem;
            color: #555;
            padding: 4px 0 4px 16px;
            position: relative;
        }

        .flip-card__list li::before {
            content: '';
            position: absolute;
            left: 0;
            top: 50%;
            transform: translateY(-50%);
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--secondary-color);
        }

        .flip-card__cta {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 0.85rem;
            font-weight: 700;
            color: var(--primary-color);
            text-decoration: none;
            padding-bottom: 2px;
            border-bottom: 2px solid var(--secondary-color);
            align-self: flex-start;
            transition: color 0.2s, gap 0.2s;
        }

        .flip-card__cta:hover {
            color: var(--secondary-color);
            gap: 10px;
        }
    </style>

    <!-- Final CTA -->
    <section style="background: #f4f1ff; text-align: center; padding: 80px 0;">
