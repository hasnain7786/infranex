<%- include('partials/header') %>

    <!-- Page Title -->
    <section style="background: var(--primary-color); color: white; padding: 60px 0; text-align: center;">
        <div class="container" data-aos="fade-down">
            <h1>Author Success Stories</h1>
            <p style="opacity: 0.8; margin-top: 10px;">The results of our passion for publishing.</p>
        </div>
    </section>

    <!-- Portfolio Grid -->
    <style>
        .portfolio-card {
            background: transparent;
            text-align: center;
            position: relative;
            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            /* Constant organic float */
            animation: portFloat 5s ease-in-out infinite alternate;
        }

        .portfolio-card:nth-child(2) {
            animation-delay: 1.5s;
        }

        .portfolio-card:nth-child(3) {
            animation-delay: 3s;
        }

        @keyframes portFloat {
            0% {
                transform: translateY(0px);
            }

            100% {
                transform: translateY(-10px);
            }
        }

        .portfolio-img-wrapper {
            position: relative;
            border-radius: 15px;
            overflow: hidden;
            margin-bottom: 25px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            transition: all 0.5s ease;
        }

        .portfolio-img {
            width: 100%;
            height: 400px;
            object-fit: cover;
            transition: transform 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
        }

        /* Glass Shimmer Sweep */
        .portfolio-img-wrapper::after {
            content: '';
            position: absolute;
            top: 0;
            left: -150%;
            width: 50%;
            height: 100%;
            background: linear-gradient(to right, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.6) 50%, rgba(255, 255, 255, 0) 100%);
            transform: skewX(-25deg);
            z-index: 2;
            transition: none;
        }

        .portfolio-card:hover .portfolio-img-wrapper::after {
            animation: portShine 0.8s ease-out forwards;
        }

        @keyframes portShine {
            0% {
                left: -150%;
            }

            100% {
                left: 200%;
            }
        }

        /* Hover Interactions */
        .portfolio-card:hover {
            transform: translateY(-15px) scale(1.02) !important;
            animation-play-state: paused;
        }

        .portfolio-card:hover .portfolio-img-wrapper {
            box-shadow: 0 30px 60px rgba(57, 43, 96, 0.25);
        }

        .portfolio-card:hover .portfolio-img {
            transform: scale(1.1);
        }

        .portfolio-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.35rem;
            color: #2D2D2D;
            font-weight: 800;
            margin-top: 5px;
            margin-bottom: 8px;
            transition: color 0.3s ease;
        }

        .portfolio-card:hover .portfolio-title {
            color: var(--secondary-color);
        }

        .portfolio-meta {
            color: var(--secondary-color);
            font-weight: 600;
            font-size: 0.9rem;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        @media (max-width: 768px) {
            .portfolio-img {
                height: 350px;
            }
        }
    </style>

    <section style="padding: 100px 0;">
        <div class="container">
            <div style="text-align: center; margin-bottom: 80px;">
                <h2 data-aos="fade-up"
                    style="font-family: 'Playfair Display', serif; font-size: 2.2rem; color: #333; margin-bottom: 12px; font-weight: 700;">
                    Our Portfolio</h2>
                <p data-aos="fade-up" data-aos-delay="100" style="color: #666; font-size: 1.1rem;">A showcase of recent
                    books we've brought to life.</p>
            </div>
            <div
                style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 50px; max-width: 1100px; margin: 0 auto;">

                <!-- Book 1 -->
                <div class="portfolio-card" data-aos="fade-up">
                    <div class="portfolio-img-wrapper">
                        <img src="https://images.unsplash.com/photo-1544716278-ca5e3f4abd8c?auto=format&fit=crop&q=80&w=600"
                            alt="The Midnight Echo" class="portfolio-img">
                    </div>
                    <h4 class="portfolio-title">The Midnight Echo</h4>
                    <p class="portfolio-meta">Thriller | Bestseller</p>
                </div>

                <!-- Book 2 -->
                <div class="portfolio-card" data-aos="fade-up" data-aos-delay="100">
                    <div class="portfolio-img-wrapper">
                        <img src="https://images.unsplash.com/photo-1516979187457-637abb4f9353?auto=format&fit=crop&q=80&w=600"
                            alt="Beyond the Binary" class="portfolio-img">
                    </div>
                    <h4 class="portfolio-title">Beyond the Binary</h4>
                    <p class="portfolio-meta">Science Fiction</p>
                </div>

                <!-- Book 3 -->
                <div class="portfolio-card" data-aos="fade-up" data-aos-delay="200">
                    <div class="portfolio-img-wrapper">
                        <img src="https://images.unsplash.com/photo-1497633762265-9d179a990aa6?auto=format&fit=crop&q=80&w=600"
                            alt="Lead with Purpose" class="portfolio-img">
                    </div>
                    <h4 class="portfolio-title">Lead with Purpose</h4>
                    <p class="portfolio-meta">Business | Leadership</p>
                </div>

            </div>
        </div>
    </section>

    <!-- Testimonials -->
